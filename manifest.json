{
  "id": "org.asyar.tauri-docs",
  "name": "Tauri Docs",
  "version": "1.1.1",
  "description": "Search and browse Tauri v2 documentation",
  "author": "Developer",
  "searchable": true,
  "icon": "📖",
  "type": "extension",
  "asyarSdk": "^2.3.0",
  "permissions": [
    "network",
    "shell:open-url"
  ],
  "preferences": [
    {
      "name": "maxResults",
      "type": "number",
      "title": "Max search results",
      "description": "How many matches to show per query (1–20).",
      "default": 5
    },
    {
      "name": "openInBrowser",
      "type": "checkbox",
      "title": "Open links in external browser",
      "description": "When enabled, clicking a result opens in the system browser instead of the in-view reader.",
      "default": false
    }
  ],
  "commands": [
    {
      "id": "open",
      "name": "Open Tauri Docs",
      "description": "Browse Tauri v2 documentation",
      "icon": "📖",
      "mode": "view",
      "component": "DefaultView",
      "searchBarAccessory": {
        "type": "dropdown",
        "default": "all",
        "options": [
          { "value": "all",             "title": "All Sections" },
          { "value": "Getting Started", "title": "Getting Started" },
          { "value": "Core Concepts",   "title": "Core Concepts" },
          { "value": "Plugins",         "title": "Plugins" },
          { "value": "Configuration",   "title": "Configuration" },
          { "value": "Distribution",    "title": "Distribution" },
          { "value": "Reference",       "title": "Reference" }
        ]
      }
    }
  ],
  "background": {
    "main": "dist/worker.js"
  }
}